# Database
DATABASE_URL=postgresql://localhost:5432/repogen

# Redis
REDIS_URL=redis://localhost:6379

# Provider API Keys (add only the ones you use)
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Privy Wallet Infrastructure (Managed Mode)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Base Network Configuration
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Treasury Wallet (receives payments from user wallets)
TREASURY_WALLET_ADDRESS=

# API Configuration
API_PORT=3001
MCP_PORT=3002
WEB_PORT=3000

# Security
API_KEY_SECRET=your-secret-for-signing-api-keys
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Environment
NODE_ENV=development
